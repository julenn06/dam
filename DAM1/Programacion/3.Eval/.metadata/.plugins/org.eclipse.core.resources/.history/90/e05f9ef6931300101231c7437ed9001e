package bista;

import java.sql.Date;
import java.util.Scanner;

import bd_Konexioa.BD_Konexioa;
import kudeatzailea.BDMetodoak;
import modeloa.Mendekoak;

public class Main {

	public static void main(String[] args) {

		BD_Konexioa konexioa = new BD_Konexioa();
		BDMetodoak metodoak = new BDMetodoak();
		Mendekoak mendekoak = new Mendekoak(0, null);

		konexioa.conectar();

		Scanner sc = new Scanner(System.in);

		int aukera = 0;
		boolean error = false;
		String izenaNagusia = "";
		String izenaMendekoa = "";
		String sartzeData = "";
		Date data = null;
		int idTaldea = 0;

		do {
			do {
				try {
					System.out.println("1. Pantailaratu Nagusi Guztiak");
					System.out.println("2. Pantailaratu Menpeko Guztiak");
					System.out.println("3. Nagusia Bilatu");
					System.out.println("4. Mendekoa Bilatu");
					System.out.println("5. Taldeko Partaideak Erakutsi");
					System.out.println("6. Menpekoa Gehitu ");
					System.out.println("9. Irten");
					aukera = sc.nextInt();
				} catch (Exception e) {
					System.out.println("Aukera Egokia aukeratu");
					sc.next();
					error = true;
				}
			} while (error);

			switch (aukera)

			{
			case 1:
				metodoak.nagusiGuztiak(konexioa);
				break;
			case 2:
				metodoak.mendekoGuztiak(konexioa);
				break;
			case 3:
				System.out.println();
				System.out.println("Idatzi nagusiaren Izena");
				izenaNagusia = sc.next();
				metodoak.nagusiaBilatu(konexioa, izenaNagusia);
				break;

			case 4:
				System.out.println();
				System.out.println("Idatzi mendekoaren Izena");
				izenaMendekoa = sc.next();
				metodoak.mendekoaBilatu(konexioa, izenaMendekoa);
				break;
			case 5:
				do {
					try {
						System.out.println("Idatzi Taldearen ID");
						idTaldea = sc.nextInt();
						error = false;
					} catch (Exception e) {
						System.out.println("Taldea zenbaki bat da");
						sc.next();
						error = true;
					}
				} while (error);
				metodoak.partaideakErakutsi(konexioa, idTaldea);
				break;
			case 6:
				System.out.println("Mendekoaren Izena: ");
				mendekoak.setIzena(sc.next());
				do {
					try {
						System.out.println("Mendekoaren Hasiera Data: ");
						sartzeData = sc.next();
						data = Date.valueOf(sartzeData);
						mendekoak.setSartzeData(data);
						error = false;
					} catch (Exception e) {
						System.out.println("Data Formatu Egokia Sartu (YYYY-MM-DD)");
						error = true;
					}
				} while (error);
				System.out.println("Kontratu Mota: ");
				mendekoak.setKontratuMota(sc.next());
				do {
					try {
						System.out.println("Idatzi Taldearen ID");
						mendekoak.setId(sc.nextInt());
						error = false;
					} catch (Exception e) {
						System.out.println("Taldea zenbaki bat da");
						sc.next();
						error = true;
					}
				} while (error);

				metodoak.mendekoaGehitu(konexioa, mendekoak);
				break;
			case 7:
				break;
			case 9:
				System.out.println("Irten...");
				break;
			}
		} while (aukera != 9);

		sc.close();

	}
}
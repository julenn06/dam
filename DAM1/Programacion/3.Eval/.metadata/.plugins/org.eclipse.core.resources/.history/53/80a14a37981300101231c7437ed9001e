	public void nagusiGuztiak(BD_Konexioa konexioa) {

		String sql = "SELECT * FROM nagusiak";

		try {

			Connection conn = konexioa.getConnection();
			PreparedStatement pstmt = conn.prepareStatement(sql);
			ResultSet rs = pstmt.executeQuery();
			if (rs.next()) {
				System.out.println("Nagusiak Datu Basean:");
				do {
					int id = rs.getInt("id");
					String izena = rs.getString("izena");
					String hasieraData = rs.getString("hasieraData");
					String maila = rs.getString("maila");
					String departamentua = rs.getString("departamentua");
					int idTalde = rs.getInt("idTalde");

					System.out.println("ID: " + id + ", Izena: " + izena + ", Hasiera Data: " + hasieraData
							+ ", Maila: " + maila + ", Departamentua: " + departamentua + ", ID Taldea: " + idTalde);
				} while (rs.next());
			} else {
				System.out.println("Ez daude Nagusirik datu basean.");
			}
		} catch (SQLException e) {
			System.out.println("Errorea Nagusiak ikustean: " + e.getMessage());
		}
	}


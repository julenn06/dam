	public void mendekoaGehitu(BD_Konexioa konexioa, Mendekoak mendekoa) {
		String sql = "INSERT INTO mendekoak (izena, hasieraData, kontratuMota, idTalde) " + "VALUES (?, ?, ?, ?)";

		try {

			Connection conn = konexioa.getConnection();
			PreparedStatement pstmt = conn.prepareStatement(sql);

			pstmt.setString(1, mendekoa.getIzena());
			pstmt.setDate(2, mendekoa.getSartzeData());
			pstmt.setString(3, mendekoa.getKontratuMota());
			pstmt.setInt(4, mendekoa.getId());

			int rowsAffected = pstmt.executeUpdate();
			if (rowsAffected > 0) {
				System.out.println("Mendekoa Datu Basean Sartuta.");
			} else {
				System.out.println("Errorea Mendekoa Sartzean.");
			}
		} catch (SQLException e) {
			System.out.println("Errorea Mendekoa Sartzean: Talde Hori Ez da Existitzen");
		}
	}


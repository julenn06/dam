package modeloa;

import java.sql.Date;

public class Mendekoak extends Langileak {

	private Date sartzeData;
	private String kontratuMota;
	
	

	public Mendekoak(int id, String izena) {
		super(id, izena);
	}

	public Date getSartzeData() {
		return sartzeData;
	}

	public void setSartzeData(Date sartzeData) {
		this.sartzeData = sartzeData;
	}

	public String getKontratuMota() {
		return kontratuMota;
	}

	public void setKontratuMota(String kontratuMota) {
		this.kontratuMota = kontratuMota;
	}

}

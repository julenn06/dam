package modeloa;

abstract class Langileak {

	protected int id;
	protected String izena;

	public Langileak(int id, String izena) {
		this.id = id;
		this.izena = izena;
	}

	public int getId() {
		return id;
	}

	public void setId(int id) {
		this.id = id;
	}

	public String getIzena() {
		return izena;
	}

	public void setIzena(String izena) {
		this.izena = izena;
	}

}
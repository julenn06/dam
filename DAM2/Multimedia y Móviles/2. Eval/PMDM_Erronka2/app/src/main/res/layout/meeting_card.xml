<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    android:layout_marginHorizontal="16dp"
    app:cardBackgroundColor="@color/primary"
    app:cardCornerRadius="16dp"
    android:elevation="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/llTarea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvMeetingTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:textColor="@color/white"
            android:textSize="18sp"
            tools:text="Reunión con Eduardo"
            android:elevation="8dp"/>

        <TextView
            android:id="@+id/tvClassroom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvMeetingTitle"
            android:layout_marginTop="8dp"
            android:background="@drawable/badge_bg"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            tools:text="Aula 1"
            android:textColor="?attr/android:textColorPrimary"
            android:textStyle="bold"
            android:textSize="11sp" />
        
        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toEndOf="@id/tvClassroom"
            app:layout_constraintTop_toBottomOf="@+id/tvMeetingTitle"
            android:layout_marginTop="8dp"
            android:background="@drawable/badge_bg"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:layout_marginStart="5dp"
            tools:text="2025-01-15"
            android:textColor="?attr/android:textColorPrimary"
            android:textStyle="bold"
            android:textSize="11sp" />
        
        <TextView
            android:id="@+id/tvHour"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toEndOf="@id/tvDate"
            app:layout_constraintTop_toBottomOf="@+id/tvMeetingTitle"
            android:layout_marginTop="8dp"
            android:background="@drawable/badge_bg"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:layout_marginStart="5dp"
            tools:text="10:00"
            android:textColor="?attr/android:textColorPrimary"
            android:textStyle="bold"
            android:textSize="11sp" />
        
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
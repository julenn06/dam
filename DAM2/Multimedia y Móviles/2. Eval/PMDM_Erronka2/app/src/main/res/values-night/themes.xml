<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ElorMovPMDM" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Colores principales adaptados -->
        <item name="colorPrimary">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/dark_primary_dark</item>
        <item name="colorOnPrimary">@color/primary_dark</item>

        <item name="colorSecondary">@color/accent_dark</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Fondos -->
        <item name="backgroundColor">@color/background_dark</item>
        <item name="colorPrimarySurface">@color/surface_dark</item>

        <!-- Texto -->
        <item name="android:textColorPrimary">@color/text_primary_dark</item>
        <item name="android:textColorSecondary">@color/text_secondary_dark</item>

        <!-- Divider -->
        <item name="android:divider">@color/divider_dark</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/background_dark</item>
    </style>

    <style name="button_style">
        <item name="backgroundColor">@color/primary_dark</item>
        <item name="cornerRadius">16dp</item>
        <item name="elevation">8dp</item>
    </style>

    <style name="text_input" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/black</item>
        <item name="boxStrokeColor">@color/primary_dark</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxStrokeWidthFocused">3dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <style name="image_bg">
        <item name="android:shape">oval</item>
        <item name="backgroundColor">@color/light_primary_dark</item>
        <item name="strokeWidth">3dp</item>
        <item name="strokeColor">@color/primary_dark</item>
    </style>

    <style name="ActiveTextStyle" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="InactiveTextStyle" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="styleLanguageSelector" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxStrokeColor">@color/primary_dark</item>

        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>

        <item name="android:textColorHint">@color/black</item>
        <item name="hintTextColor">@color/light_primary_dark</item>
    </style>

    <style name="Theme.ElorMovPMDM" parent="Base.Theme.ElorMovPMDM" />
</resources>
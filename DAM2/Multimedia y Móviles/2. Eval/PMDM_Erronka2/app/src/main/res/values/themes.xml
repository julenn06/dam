<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ElorMovPMDM" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Colores principales -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/dark_primary</item>
        <item name="colorOnPrimary">@color/primary</item>

        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Fondos -->
        <item name="backgroundColor">@color/white</item>
        <item name="colorPrimarySurface">@color/light_primary</item>

        <!-- Texto -->
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/secondary_text</item>

        <!-- Divider -->
        <item name="android:divider">@color/divider</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/dark_primary</item>
    </style>

    <style name="button_style">
        <item name="backgroundColor">@color/primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="elevation">8dp</item>
    </style>

    <style name="text_input" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">?attr/backgroundColor</item>
        <item name="boxStrokeColor">?attr/android:textColorPrimary</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxStrokeWidthFocused">3dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>
    
    <style name="image_bg">
        <item name="android:shape">oval</item>
        <item name="backgroundColor">@color/light_primary</item>
        <item name="strokeWidth">3dp</item>
        <item name="strokeColor">@color/primary</item>
    </style>

    <style name="ActiveTextStyle" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="InactiveTextStyle" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="styleLanguageSelector" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxStrokeColor">?attr/android:textColorPrimary</item>

        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>

        <item name="android:textColorHint">?attr/android:textColorPrimary</item>
        <item name="hintTextColor">?attr/android:textColorSecondary</item>
    </style>
    
    <style name="Theme.ElorMovPMDM" parent="Base.Theme.ElorMovPMDM" />
</resources>